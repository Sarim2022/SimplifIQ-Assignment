PORT=3000

# Gemini AI — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# Gmail SMTP — use an App Password (not your normal password)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Optional: verbose pipeline logs in terminal
DEBUG_PIPELINE=false

# BONUS — Google Sheets & Drive (Phase 9)
GOOGLE_SHEET_ID=your_google_sheet_id
# Folder ID (must be shared with service account as Editor; Shared Drive folder recommended)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/your-service-account.json
# Optional: default Sheet1!A:G — Name, Email, Company, Website, Timestamp, Status, Request ID
GOOGLE_SHEET_RANGE=Sheet1!A:G
# Optional: only if folder lives inside a Shared Drive and upload still fails
GOOGLE_SHARED_DRIVE_ID=
# Optional: Google Workspace only — domain-wide delegation (uploads use this user's Drive quota)
GOOGLE_IMPERSONATE_USER=
